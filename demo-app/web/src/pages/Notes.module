/* 노트 페이지 스타일 */

/* 전체 배경 */
.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 0 0 48px;
}

/* 최대 너비 제한 + 좌우 여백 */
.inner {
  max-width: 640px;
  margin: 0 auto;
  padding: 0 20px;
}

/* 헤더 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24px 0 20px;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 24px;
}

.headerLeft {
  display: flex;
  align-items: center;
  gap: 12px;
}

/* 로고 */
.logo {
  width: 38px;
  height: 38px;
  background: var(--color-accent);
  color: #fff;
  font-size: 17px;
  font-weight: 600;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.title {
  font-size: 17px;
  font-weight: 600;
  line-height: 1.2;
}

.greeting {
  font-size: 12px;
  color: var(--color-text-sub);
  margin-top: 1px;
}

/* 로그아웃 버튼 */
.logoutBtn {
  padding: 6px 14px;
  background: transparent;
  color: var(--color-text-sub);
  border: 1px solid var(--color-border);
  font-size: 13px;
  border-radius: var(--radius-sm);
}

.logoutBtn:hover {
  background: var(--color-bg);
  color: var(--color-text-primary);
}

/* 입력 폼 섹션 */
.formSection {
  margin-bottom: 28px;
}

/* 오류 메시지 */
.error {
  font-size: 13px;
  color: var(--color-danger);
  background: #FEF2F2;
  border: 1px solid #FECACA;
  border-radius: var(--radius-sm);
  padding: 8px 12px;
  margin-bottom: 16px;
}

/* 목록 섹션 */
.listSection {}

.listMeta {
  font-size: 12px;
  color: var(--color-text-sub);
  margin-bottom: 12px;
  font-variant-numeric: tabular-nums;
}

/* 로딩 스켈레톤 */
.skeletonWrap {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.skeleton {
  height: 72px;
  background: linear-gradient(90deg, #ECECEC 25%, #F5F5F5 50%, #ECECEC 75%);
  background-size: 200% 100%;
  border-radius: var(--radius-md);
  animation: shimmer 1.4s infinite;
}

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 빈 상태 */
.empty {
  text-align: center;
  padding: 48px 0;
  color: var(--color-text-sub);
}

.emptyTitle {
  font-size: 15px;
  font-weight: 500;
  margin-bottom: 6px;
  color: var(--color-text-primary);
}

.emptySub {
  font-size: 13px;
}

/* 노트 카드 */
.noteCard {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 14px 16px;
  margin-bottom: 8px;
  transition: box-shadow 0.15s;
}

.noteCard:hover {
  box-shadow: var(--shadow-card);
}

.noteContent {
  font-size: 14px;
  line-height: 1.65;
  color: var(--color-text-primary);
  white-space: pre-wrap;   /* 줄바꿈 유지 */
  word-break: break-word;
}

.noteMeta {
  font-size: 11px;
  color: var(--color-text-sub);
  margin-top: 8px;
  font-family: var(--font-mono);
}
